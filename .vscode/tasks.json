{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build all",
            "type": "shell",
            "command": "gcc.exe",
            "args": [
                "-g",
                "main.c",
                "src/calculateStopNumber.c",
                "src/calculateTyreLife.c",
                "src/menus.c",
                "src/globalVariables.c",
                "-o",
                "main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}